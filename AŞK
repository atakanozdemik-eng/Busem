<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Busem & Atakan 💗</title>

<style>
body{
  margin:0;
  font-family:Arial;
  background: linear-gradient(135deg,#ff9a9e,#fad0c4);
}

/* GİRİŞ */
.start{
  height:100vh;
  display:flex;
  justify-content:center;
  align-items:center;
  text-align:center;
}

.note{
  background:white;
  padding:25px;
  border-radius:20px;
  max-width:600px;
  box-shadow:0 10px 30px rgba(0,0,0,0.2);
  animation:pop 1s;
}

@keyframes pop{
  from{transform:scale(0.7);opacity:0;}
  to{transform:scale(1);opacity:1;}
}

button{
  margin-top:15px;
  padding:12px 18px;
  border:none;
  background:#ff3b6b;
  color:white;
  border-radius:10px;
  cursor:pointer;
}

/* GALERİ */
.gallery{
  display:none;
  padding:20px;
  text-align:center;
}

.hero{
  width:90%;
  max-width:600px;
  border-radius:20px;
  border:5px solid white;
  box-shadow:0 10px 20px rgba(0,0,0,0.2);
}

.grid{
  margin-top:20px;
  display:flex;
  gap:10px;
  flex-wrap:wrap;
  justify-content:center;
}

.grid img{
  width:160px;
  height:160px;
  object-fit:cover;
  border-radius:15px;
  border:3px solid white;
}

/* SKOR */
.scoreboard{
  display:none;
  text-align:center;
  margin-top:40px;
}

.box{
  background:white;
  padding:30px;
  border-radius:20px;
  display:inline-block;
  font-size:22px;
  font-weight:bold;
}
</style>
</head>

<body>

<!-- GİRİŞ -->
<div class="start" id="start">
  <div class="note">
    <h2>Busem 💗</h2>
    <p>
      Busemm seni tüm kalbimle seviyorumm aşkımm bazen şapşikce davranıp seni sinirlendiriyorum ama biliyorsun gerçekten öyle bişey istemem seni çok seviyorumm bebeğimm 💗💗💗💗💗💗💗💗
    </p>
    <button onclick="openSite()">Devam Et 💌</button>
  </div>
</div>

<!-- GALERİ -->
<div class="gallery" id="gallery">

  <!-- BAŞ KÖŞE FOTO -->
  <img class="hero" src="https://photos.google.com/photo/AF1QipMiIXh9bATPDslYaiLpgY-LwS3f1_waxSwDMzoN" />

  <h3 style="margin-top:15px;">Biz 💑</h3>

  <div class="grid">
    <img src="https://photos.google.com/photo/AF1QipMDKSFrooyKTBO6uksj8aGMZ6WAoI0R0uvR6T9W">
    <img src="https://photos.google.com/photo/AF1QipP9r6-PxfJ8fqMYqvRsYJdsmoO74EEB9XkRThvp">
    <img src="https://photos.google.com/photo/AF1QipMAS714oV6yqhtuTLz6ZB96NmoesCQIHPyskUZb">
  </div>

  <button onclick="showScore()">Butona Bas 💖</button>

</div>

<!-- SKOR -->
<div class="scoreboard" id="scoreboard">
  <div class="box">
    1. Busem 💗<br/>
    2. Atakan 💙
  </div>
</div>

<script>
function openSite(){
  document.getElementById("start").style.display="none";
  document.getElementById("gallery").style.display="block";
}

function showScore(){
  document.getElementById("gallery").style.display="none";
  document.getElementById("scoreboard").style.display="block";
}
</script>

</body>
</html>
